{
  "type": "module",
  "private": true,
  "scripts": {
    "base:dev": "cross-env NODE_ENV=development bun --env-file=./.env.development.local",
    "base:prod": "cross-env NODE_ENV=production bun --env-file=./.env.production.local",
    "bootstrap:dev": "bun run base:dev -- run ./src/core/bootstrap/index.ts",
    "bootstrap:prod": "bun run base:prod -- run ./src/core/bootstrap/index.ts",
    "build": "bun run base:prod -- run ./src/core/build.ts",
    "depcheck": "depcheck",
    "dev": "cross-env NODE_ENV=development nodemon",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix --max-warnings 0",
    "typecheck": "tsc",
    "unused-exports": "ts-unused-exports ./tsconfig.json"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "es-toolkit": "^1.45.1",
    "hono": "^4.12.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@hono/swagger-ui": "^0.6.0",
    "@kikiutils/eslint-config": "^7.0.1",
    "@kikiutils/tsconfigs": "^5.1.0",
    "@scalar/hono-api-reference": "^0.10.0",
    "@types/bun": "^1.3.10",
    "cross-env": "^10.1.0",
    "depcheck": "^1.4.7",
    "mlly": "^1.8.1",
    "nodemon": "^3.1.14",
    "openapi3-ts": "^4.5.0",
    "ts-unused-exports": "^11.0.1",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3",
    "unimport": "^6.0.1"
  }
}
